# Guised Up — Laravel Backend Environment
# Copy to .env and configure for your environment

APP_NAME="Guised Up"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL 16.6 + pgvector (extension enabled via docker/postgres/init.sql)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=guisedup
DB_USERNAME=guisedup
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

# Redis 7.4 (optional cache)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Embedding Service (Python FastAPI)
EMBEDDING_SERVICE_URL=http://127.0.0.1:8001
EMBEDDING_PROVIDER=http
EMBEDDING_TIMEOUT=5
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Feed Ranking Weights (frozen defaults)
FEED_WEIGHT_SEMANTIC=0.40
FEED_WEIGHT_RELATIONSHIP=0.30
FEED_WEIGHT_AUTHENTICITY=0.20
FEED_WEIGHT_TIME=0.10

# Feed Configuration
FEED_PER_PAGE=20
FEED_CANDIDATE_LIMIT=500
FEED_CANDIDATE_DAYS=30

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1
