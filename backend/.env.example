# Guised Up — Laravel Backend Environment
# Copy to .env and configure for your environment

APP_NAME="Guised Up"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL 16.6
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=guisedup
DB_USERNAME=guisedup
DB_PASSWORD=secret

# Redis 7.4 (optional cache)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Embedding Service (Python FastAPI)
EMBEDDING_SERVICE_URL=http://embedding:8001
EMBEDDING_PROVIDER=http
EMBEDDING_TIMEOUT=5

# Feed Ranking Weights (frozen defaults)
FEED_WEIGHT_SEMANTIC=0.40
FEED_WEIGHT_RELATIONSHIP=0.30
FEED_WEIGHT_AUTHENTICITY=0.20
FEED_WEIGHT_TIME=0.10

# Feed Configuration
FEED_PER_PAGE=20
FEED_CANDIDATE_LIMIT=500
FEED_CANDIDATE_DAYS=30

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1
