# Guised Up — Python Embedding Service Environment
# Copy to .env and configure for your environment

# Model configuration
MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
MAX_INPUT_TOKENS=512
MAX_BATCH_SIZE=32
INFERENCE_TIMEOUT_SECONDS=5.0

# Server
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# Model cache directory (use /app/.cache in Docker)
TRANSFORMERS_CACHE=.cache
